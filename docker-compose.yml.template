services:
  fabric-jupyter:
    build:
      context: .
      dockerfile: .docker/Dockerfile
      args:
        FABRIC_PROJECT_ID: "FABRIC1003042"
        FABRIC_BASTION_USERNAME: "ec1053226_0000480805"
    image: fabric-jupyter:local
    container_name: fabric-jupyter
    working_dir: /app
    ports:
      - "8888:8888"
      - "3000:3000"
      - "4000:4000"
      - "8080:8080"
    volumes:
      - .:/app
    stdin_open: true
    tty: true
